{
  "rounds": 1,
  "agenda_items": 5,
  "max_stakeholders": 5,
  "low_confidence_threshold": 0.7,
  "tool_call_max_rounds": 3,
  "max_iterations": {
    "expert_phase0": 3,
    "modeler_phase0": 3,
    "expert_review": 3,
    "analyst_review": 3,
    "modeler_review": 3
  },
  "enable_tools": {
    "web_search": true,
    "file_parser": true,
    "read_external_file": true,
    "plantuml_validate": true
  },
  "enable_human_escalation": true,
  "enable_agenda_types": {
    "conflict_resolution": true,
    "requirement_clarification": true,
    "open_question": true,
    "new_requirement": true,
    "tradeoff": true
  },
  "enable_agents": {
    "user": true,
    "analyst": true,
    "expert": true,
    "mediator": true,
    "modeler": true,
    "documentor": true
  },
  "agent_models": {
    "default": {
      "provider": "openai",
      "model": "gpt-4.1",
      "temperature": 0
    },
    "user": {
      "provider": "openai",
      "model": "gpt-4o-mini",
      "temperature": 1
    },
    "analyst": {
      "provider": "openai",
      "model": "gpt-4.1",
      "temperature": 0
    },
    "expert": {
      "provider": "openai",
      "model": "gpt-4.1",
      "temperature": 0
    },
    "mediator": {
      "provider": "openai",
      "model": "gpt-4.1",
      "temperature": 0
    },
    "modeler": {
      "provider": "openai",
      "model": "gpt-4.1",
      "temperature": 0
    },
    "documentor": {
      "provider": "openai",
      "model": "gpt-4.1",
      "temperature": 0
    }
  }
}