# remove if not needed

# host: 127.0.0.1 or your public domain
frontend_host=127.0.0.1

# Activation codes (at least 8 characters each; comma-separated for multiple codes)
activation_code=change-me

# Tavily Web Search API Key (optional)
# If not configured, set enable_tools.web_search to false in config.json
# Apply at: https://app.tavily.com/home
TAVILY_API_KEY=your_tavily_api_key

# Local model
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_API_KEY=local_api_key

# OpenAI API Key
# Apply at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key

# Google Gemini API Key
# Apply at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_ai_studio_api_key

# Anthropic Claude API Key
# Apply at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key
