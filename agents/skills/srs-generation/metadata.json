{
  "name": "srs-generation",
  "description": "將最新需求草稿轉換為正式 SRS 文件（ISO/IEC/IEEE 29148）。",
  "triggers": [
    "需要正式 SRS 產出",
    "需求草稿已完成並需定稿"
  ],
  "inputs": {
    "required": ["draft_markdown"],
    "optional": ["feedback", "domain_research"]
  },
  "tools": {
    "allowed": [],
    "external": [],
    "prerequisites": []
  },
  "workflow": {
    "steps": [
      "載入最新 draft",
      "對照模板與 checklist",
      "轉寫為正式 SRS",
      "清理非必要章節"
    ]
  },
  "outputs": {
    "artifacts": ["srs.md", "design_rationale.md"]
  },
  "integration": {
    "upstream": ["requirements-analyst", "conflict-analyzer"],
    "downstream": ["final_artifact_delivery"],
    "related": ["domain-research"]
  },
  "quality": {
    "acceptance_criteria": [
      "章節符合模板",
      "需求不新增、不遺漏",
      "編號格式一致且可追溯"
    ]
  }
}
