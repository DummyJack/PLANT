{
  "name": "plantuml-ascii",
  "description": "將需求或衝突分析結果轉為可讀的 PlantUML ASCII 圖文輸出。",
  "triggers": [
    "需要圖文化需求或衝突結果",
    "產生或調整 UML/PlantUML"
  ],
  "inputs": {
    "required": ["requirements_or_conflicts"],
    "optional": ["stakeholders", "existing_models"]
  },
  "tools": {
    "allowed": ["plantuml_validate"],
    "external": [],
    "prerequisites": ["PlantUML server or jar for validation"]
  },
  "workflow": {
    "steps": [
      "依需求決定圖型",
      "生成 PlantUML 文字",
      "驗證語法",
      "回傳可渲染圖文內容"
    ]
  },
  "outputs": {
    "artifacts": ["plantuml_code", "diagram_markdown"]
  },
  "integration": {
    "upstream": ["requirements-analyst", "conflict-analyzer"],
    "downstream": ["draft_markdown", "review_materials"],
    "related": ["srs-generation", "modeler"]
  },
  "quality": {
    "acceptance_criteria": [
      "PlantUML 可驗證",
      "圖中元素命名一致",
      "能對應回需求 id 或議題"
    ]
  }
}
